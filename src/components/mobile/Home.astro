---
import Placeholder from '../shared/Placeholder.astro';
import PostFlags from '../shared/PostFlags.astro';
import Pagination from '../shared/Pagination.astro';
import Footer from './Footer.astro';
import { postUrl } from '../../lib/urls.js';

interface Props { posts: any[]; pageNum?: number; totalPages?: number; }
const { posts, pageNum = 1, totalPages = 1 } = Astro.props;

const isFirst = pageNum === 1;
const featured = isFirst ? posts[0] : null;
const tiles = isFirst ? posts.slice(1, 3) : [];
const list = isFirst ? posts.slice(3) : posts;
---
<div>
  {featured && (
    <a class="feature" href={postUrl(featured)}>
      <div class="feature-img">
        <Placeholder variant={featured.cover} label={featured.coverLabel} />
      </div>
      <PostFlags post={featured} />
      <div class="feature-title">{featured.title}</div>
    </a>
  )}

  {tiles.length > 0 && (
    <div class="grid-2">
      {tiles.map((p) => (
        <a class="tile" href={postUrl(p)}>
          <div class="tile-img">
            <Placeholder variant={p.cover} label={p.coverLabel} />
          </div>
          <div class="tile-title">{p.title}</div>
        </a>
      ))}
    </div>
  )}

  {list.map((p) => (
    <a class="post-card" href={postUrl(p)}>
      <div class="post-card-img">
        <PostFlags post={p} />
        <Placeholder variant={p.cover} label={p.coverLabel} />
      </div>
      <div class="post-card-body">
        <h3 class="post-card-title">{p.title}</h3>
        <div class="post-card-meta">
          <span class="m">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            {p.views}
          </span>
          <span class="m">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            {p.likes}
          </span>
        </div>
      </div>
    </a>
  ))}

  <Pagination current={pageNum} total={totalPages} class="m-pagination" />

  <div class="foot-pad"></div>
  <Footer />
</div>
