---
import Header from './Header.astro';
import Drawer from './Drawer.astro';
import Home from './Home.astro';
import Article from './Article.astro';
import Category from './Category.astro';
import Archive from './Archive.astro';
import About from './About.astro';
import Links from './Links.astro';
import Tag from './Tag.astro';
import Search from './Search.astro';
import NotFound from './NotFound.astro';
import { config } from '../../config.js';

interface Props {
  page?: string;
  posts?: any[];
  post?: any;
  tag?: string;
  readMin?: number;
  pageNum?: number;
}
const { page = 'home', posts = [], post, tag, readMin, pageNum = 1 } = Astro.props;

const PAGE_SIZE = config.pagination.pageSize;
const totalPages = Math.ceil(posts.length / PAGE_SIZE);
const pageStart = (pageNum - 1) * PAGE_SIZE;
const homePosts = posts.slice(pageStart, pageStart + PAGE_SIZE);

const postIdx = post ? posts.findIndex((p) => p.id === post.id) : -1;
const prevPost = postIdx > 0 ? posts[postIdx - 1] : null;
const nextPost = postIdx >= 0 && postIdx < posts.length - 1 ? posts[postIdx + 1] : null;
---
<div class="app">
  <div class="app-scroll">
    <Header />
    {page === 'home' && <Home posts={homePosts} pageNum={pageNum} totalPages={totalPages} />}
    {page === 'article' && post && (
      <Article post={post} posts={posts} prevPost={prevPost} nextPost={nextPost} readMin={readMin}>
        <slot />
      </Article>
    )}
    {page === 'category' && <Category posts={posts} />}
    {page === 'archive' && <Archive posts={posts} />}
    {page === 'about' && <About />}
    {page === 'links' && <Links />}
    {page === 'search' && <Search posts={posts} />}
    {page === 'tag' && <Tag posts={posts} tag={tag} />}
    {page === '404' && <NotFound />}
  </div>

  <button class="float-top" data-scroll-top data-scroll-watch="window" aria-label="scroll to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 19V5M5 12l7-7 7 7"/>
    </svg>
  </button>

  <button class="float-moon" data-theme-toggle aria-label="toggle theme">
    <svg class="theme-icon-dark" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <circle cx="12" cy="12" r="4"/>
      <path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4l1.4-1.4M17 7l1.4-1.4"/>
    </svg>
    <svg class="theme-icon-light" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z"/>
    </svg>
  </button>

  <Drawer currentPage={page} />
</div>
