---
import Placeholder from '../../shared/Placeholder.astro';
import Footer from '../Footer.astro';
import { LINKS, hostOf } from '../../../data/links.js';
---
<div class="pc-center">
  <div class="pc-inner-head">
    <h2 class="pc-inner-title serif">友链</h2>
    <span class="pc-inner-count">{LINKS.length} 个</span>
  </div>
  <div class="pc-links-grid">
    {LINKS.map((l) => (
      <a class="pc-links-card" href={l.url} target="_blank" rel="noopener noreferrer">
        <div class="pc-links-img">
          <Placeholder variant={l.variant} label="" />
        </div>
        <div class="pc-links-text">
          <div class="pc-links-name">{l.name}</div>
          <div class="pc-links-desc">{l.desc}</div>
          <div class="pc-links-host">
            <span>{hostOf(l.url)}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M8 7h9v9" />
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>
  <Footer />
</div>
