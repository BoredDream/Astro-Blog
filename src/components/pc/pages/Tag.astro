---
import Placeholder from '../../shared/Placeholder.astro';
import { postUrl } from '../../../lib/urls.js';

interface Props { posts: any[]; tag: string; }
const { posts, tag } = Astro.props;
const filtered = posts.filter((p) => p.tags.includes(tag));
---
<div class="pc-center">
  <div class="pc-inner-head">
    <a href="/categories" style="display:inline-flex;align-items:center;color:var(--pc-ink-3);padding-right:8px">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M19 12H5M12 5l-7 7 7 7"/>
      </svg>
    </a>
    <h2 class="pc-inner-title">#{tag}</h2>
    <span class="pc-inner-count">{filtered.length} 篇</span>
  </div>
  <div class="pc-list">
    {filtered.map((p) => (
      <a class="pc-card" href={postUrl(p)}>
        <div class="pc-card-img">
          <Placeholder variant={p.cover} label={p.coverLabel} />
        </div>
        <div class="pc-card-body">
          <div>
            <h3 class="pc-card-title">{p.title}</h3>
            {p.excerpt && <p class="pc-card-excerpt">{p.excerpt}</p>}
          </div>
          <div class="pc-card-foot">
            <span>{p.date.slice(0, 10)}</span>
            <span>{p.relTime}</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</div>
