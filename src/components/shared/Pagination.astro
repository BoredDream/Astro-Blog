---
import { pageUrl } from '../../lib/urls.js';

// 生成页码序列：首页 + 尾页 + 当前页 ±2，其余用省略号。
function buildPages(current: number, total: number) {
  const delta = 2;
  const left = Math.max(2, current - delta);
  const right = Math.min(total - 1, current + delta);
  const pages: (number | string)[] = [1];
  if (left > 2) pages.push('…');
  for (let i = left; i <= right; i++) pages.push(i);
  if (right < total - 1) pages.push('…');
  if (total > 1) pages.push(total);
  return pages;
}

interface Props {
  current?: number;
  total?: number;
  class?: string;
}
const { current = 1, total = 1, class: className = 'pc-pagination' } = Astro.props;
const pages = total > 1 ? buildPages(current, total) : [];
---
{total > 1 && (
  <nav class={className} aria-label="分页导航">
    {current > 1
      ? <a class="pg-arrow" href={pageUrl(current - 1)} aria-label="上一页">‹</a>
      : <span class="pg-arrow disabled" aria-hidden="true">‹</span>}

    {pages.map((p) =>
      p === '…'
        ? <span class="ellipsis">…</span>
        : p === current
          ? <span class="active" aria-current="page">{p}</span>
          : <a href={pageUrl(p as number)}>{p}</a>
    )}

    {current < total
      ? <a class="pg-arrow" href={pageUrl(current + 1)} aria-label="下一页">›</a>
      : <span class="pg-arrow disabled" aria-hidden="true">›</span>}
  </nav>
)}
