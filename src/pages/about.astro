---
import Layout from '../layouts/Layout.astro';
import PCShell from '../components/pc/PCShell.astro';
import MobileShell from '../components/mobile/MobileShell.astro';
import { getPosts } from '../lib/posts.js';
import { config } from '../config.js';

const posts = await getPosts();
---
<Layout title={`关于 · ${config.site.name}`} description={`关于${config.site.name}和它的作者。`}>
  <PCShell page="about" posts={posts} />
  <MobileShell page="about" posts={posts} />
</Layout>
