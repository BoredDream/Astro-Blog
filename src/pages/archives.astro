---
import Layout from '../layouts/Layout.astro';
import PCShell from '../components/pc/PCShell.astro';
import MobileShell from '../components/mobile/MobileShell.astro';
import { getPosts } from '../lib/posts.js';
import { config } from '../config.js';

const posts = await getPosts();
---
<Layout title={`归档 · ${config.site.name}`} description={`${config.site.name}的文章按时间归档。`}>
  <PCShell page="archive" posts={posts} />
  <MobileShell page="archive" posts={posts} />
</Layout>
