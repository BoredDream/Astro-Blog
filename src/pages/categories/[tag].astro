---
import Layout from '../../layouts/Layout.astro';
import PCShell from '../../components/pc/PCShell.astro';
import MobileShell from '../../components/mobile/MobileShell.astro';
import { getBlogEntries, getPosts } from '../../lib/posts.js';
import { config } from '../../config.js';

export async function getStaticPaths() {
  const entries = await getBlogEntries();
  const tags = [...new Set(entries.flatMap((e) => e.data.tags))];
  return tags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.props;
const posts = await getPosts();
---
<Layout title={`#${tag} · ${config.site.name}`} description={`标签「${tag}」下的全部文章。`}>
  <PCShell page="tag" posts={posts} tag={tag} />
  <MobileShell page="tag" posts={posts} tag={tag} />
</Layout>
