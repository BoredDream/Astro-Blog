---
import Layout from '../../layouts/Layout.astro';
import PCShell from '../../components/pc/PCShell.astro';
import MobileShell from '../../components/mobile/MobileShell.astro';
import { getPosts } from '../../lib/posts.js';
import { config } from '../../config.js';

const posts = await getPosts();
---
<Layout title={`分类 · ${config.site.name}`} description={`按标签浏览${config.site.name}的全部文章。`}>
  <PCShell page="category" posts={posts} />
  <MobileShell page="category" posts={posts} />
</Layout>
