---
import Layout from '../layouts/Layout.astro';
import PCShell from '../components/pc/PCShell.astro';
import MobileShell from '../components/mobile/MobileShell.astro';
import { getPosts } from '../lib/posts.js';
import { config } from '../config.js';

const posts = await getPosts();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: config.site.name,
  description: config.site.description,
  url: config.site.url,
};
---
<Layout jsonLd={jsonLd}>
  <PCShell page="home" posts={posts} pageNum={1} />
  <MobileShell page="home" posts={posts} pageNum={1} />
</Layout>
