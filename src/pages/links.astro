---
import Layout from '../layouts/Layout.astro';
import PCShell from '../components/pc/PCShell.astro';
import MobileShell from '../components/mobile/MobileShell.astro';
import { getPosts } from '../lib/posts.js';
import { config } from '../config.js';

const posts = await getPosts();
---
<Layout title={`友链 · ${config.site.name}`} description={`${config.site.name}的友情链接。`}>
  <PCShell page="links" posts={posts} />
  <MobileShell page="links" posts={posts} />
</Layout>
