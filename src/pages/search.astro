---
import Layout from '../layouts/Layout.astro';
import PCShell from '../components/pc/PCShell.astro';
import MobileShell from '../components/mobile/MobileShell.astro';
import { getPosts } from '../lib/posts.js';
import { config } from '../config.js';

const posts = await getPosts();
// 仅向客户端暴露搜索所需字段，避免泄露多余数据 & 减小体积。
const searchData = posts.map((p) => ({
  id: p.id,
  title: p.title,
  tags: p.tags,
  excerpt: p.excerpt || '',
  date: p.date,
  cover: p.cover,
  coverLabel: p.coverLabel,
}));
const searchJson = JSON.stringify(searchData).replace(/</g, '\\u003c');
---
<Layout title={`搜索 · ${config.site.name}`} description={`搜索${config.site.name}的文章。`}>
  <PCShell page="search" posts={posts} />
  <MobileShell page="search" posts={posts} />
  <script type="application/json" id="search-data" set:html={searchJson}></script>
  <script>import '../scripts/search.js';</script>
</Layout>
